# =====================================================================
# LAW 1 -- DATA SOVEREIGNTY (CUI). Schedule data must NEVER be committed.
# Block every schedule-bearing format at the VCS layer (fail closed).
# Covers the full §0.1 intake set plus common derivatives.
# =====================================================================
*.mpp
*.mpp.bak
*.mpt
*.mpx
*.xer
*.xml
*.pmxml
*.csv
*.xls
*.xlsx
*.pbix
*.mspdi
docs/sources/*.mpp

# =====================================================================
# REFERENCE INTAKE (00_REFERENCE_INTAKE/) — the user deposits possibly-CUI
# reference/golden files here at Gate 1. Block EVERYTHING in this folder
# except the deposit instructions, so a deposited file can never be
# committed by accident. Fail closed.
# =====================================================================
00_REFERENCE_INTAKE/*
!00_REFERENCE_INTAKE/DEPOSIT-HERE.md
!00_REFERENCE_INTAKE/.gitkeep

# Runtime data directories (uploads / parsed / derived / exports).
session_data/
uploads/
exports/
local_validation_results/
# Real golden-parity cases live OUTSIDE the repo or here (CUI inputs, LAW 1):
# never commit real reference cases; only synthetic/self cases under tests/fixtures.
local_parity/

# NOTE (deliberate deviation from the master directive's "*.json"): we do NOT
# globally ignore *.json, because tracked config (e.g. .claude/settings.json,
# package manifests) is JSON. Schedule JSON is instead blocked by the runtime
# data directories above. Rationale logged in docs/HAZARDS.md.

# ---------------------------------------------------------------------
# EXCEPTION: synthetic, hand-authored test fixtures are the ONLY
# schedule-format files allowed in-repo. They contain no real data.
# ---------------------------------------------------------------------
!tests/fixtures/
!tests/fixtures/**

# --- Python / tooling / build ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.egg-info/
build/
dist/
*.log

# --- MPXJ runner: the prebuilt MPXJ jars + compiled MpxjToMspdi converter ARE
#     committed so native .mpp parsing works with ONLY a Java runtime (no Maven,
#     no build step). Exception: the ~14 MB P6-SQLite driver is NOT committed
#     (it is only used for Primavera P6 SQLite, never for .mpp); a local
#     tools/mpxj/setup.* re-run would re-fetch it, but it stays out of git. ---
tools/mpxj/lib/sqlite-jdbc*.jar
