{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git config:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(coverage:*)",
      "Bash(pip:*)",
      "Bash(pip install:*)",
      "Bash(python -m pip:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(ollama list)",
      "Bash(ollama ps)",
      "Bash(ollama show:*)",
      "Bash(ollama pull:*)",
      "Bash(ollama run:*)",
      "Bash(java:*)",
      "Bash(javac:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/session_start.sh" }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/session_start.sh" }
        ]
      }
    ]
  }
}
