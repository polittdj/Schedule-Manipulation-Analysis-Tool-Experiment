#!/usr/bin/env bash
# =====================================================================================
# Schedule Forensics — one-file installer (Tier 3 - 128 GB RAM + discrete GPU) — macOS
# =====================================================================================
# Generated by tools/installer/build_installers.py — DO NOT hand-edit below the CONFIG
# block; regenerate instead. Double-click to run (or: bash install-tier3.command).
#
# Steps (checking before installing — nothing already present is reinstalled):
#   1. Machine-fit check (RAM/GPU) — warns, never blocks.
#   2. Python 3.11+ (offers Homebrew install if missing).
#   3. The tool into its OWN venv from the wheel EMBEDDED in this file.
#   4. Optional Ollama + this tier's AI model (skippable).
#   5. Desktop "Start"/"Stop" .command launchers, uninstaller, first-run README.
#
# DATA SOVEREIGNTY: the installed tool binds 127.0.0.1 only — schedule data never
# leaves the machine. Internet is used ONLY at install time for public prerequisites.
# Non-interactive smoke test:  SF_INSTALLER_SMOKE=1 bash install-tier3.command
# =====================================================================================

# ------------------------------- TIER CONFIG (edit freely) --------------------------
# Defaults chosen 2026-07-02 per INSTALLER-SPEC.md SS3 (operator authorized autonomous build;
# edit these five lines freely - they are the ONLY tier-specific values in this file).
TIER_LABEL="Tier 3 - 128 GB RAM + discrete GPU"
MIN_RAM_GB=128
NEEDS_GPU=true
OLLAMA_MODEL="llama3.3:70b"
MODEL_DISK_GB=43
# ---------------------------- END TIER CONFIG — SHARED BODY -------------------------

set -euo pipefail
SMOKE="${SF_INSTALLER_SMOKE:-0}"
if [ "$SMOKE" = "1" ]; then
  INSTALL_ROOT="${SF_INSTALL_ROOT:-$(mktemp -d)/ScheduleForensics}"
else
  INSTALL_ROOT="${SF_INSTALL_ROOT:-$HOME/Library/Application Support/ScheduleForensics}"
fi
VENV_DIR="$INSTALL_ROOT/venv"
APP_PORT=8321
mkdir -p "$INSTALL_ROOT"

step() { printf '\n\033[36m==> %s\033[0m\n' "$1"; }
ok()   { printf '    \033[32m[ok]\033[0m %s\n' "$1"; }
warn() { printf '    \033[33m[!!]\033[0m %s\n' "$1"; }

echo ""
echo "Schedule Forensics installer — ${TIER_LABEL}"
echo "Install location: $INSTALL_ROOT"

# --- 1. machine fit (warn-only) ------------------------------------------------------
step "Checking machine fit for this tier"
ram_gb=$(( $(sysctl -n hw.memsize) / 1024 / 1024 / 1024 ))
if [ "$ram_gb" -lt "$MIN_RAM_GB" ]; then
  warn "This machine reports ${ram_gb} GB RAM; this tier targets ${MIN_RAM_GB} GB+. The tool will run; the AI model may be slow or fail to load."
else
  ok "${ram_gb} GB RAM (tier targets ${MIN_RAM_GB} GB+)"
fi
if [ "$NEEDS_GPU" = "true" ]; then
  ok "Apple-silicon unified memory serves as GPU memory for Ollama (no discrete GPU needed)"
fi

# --- 2. Python 3.11+ ------------------------------------------------------------------
step "Checking Python 3.11+"
PY=""
for cand in python3.13 python3.12 python3.11 python3; do
  if command -v "$cand" >/dev/null 2>&1; then
    if "$cand" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)'; then
      PY="$cand"; break
    fi
  fi
done
if [ -z "$PY" ]; then
  if command -v brew >/dev/null 2>&1 && [ "$SMOKE" != "1" ]; then
    warn "Python 3.11+ not found — installing via Homebrew"
    brew install python@3.12
    PY="$(command -v python3.12 || command -v python3)"
  else
    echo "Python 3.11+ not found. Install it from python.org or via Homebrew (brew install python@3.12), then re-run." >&2
    exit 1
  fi
fi
ok "Python found: $PY ($($PY -V))"

# --- 3. the tool, into its own venv, from the wheel embedded below --------------------
step "Installing Schedule Forensics into its own environment"
if [ ! -x "$VENV_DIR/bin/python" ]; then
  "$PY" -m venv "$VENV_DIR"
  ok "Created venv"
else
  ok "venv already present (re-using)"
fi
WHEEL_PATH="$INSTALL_ROOT/schedule_forensics-1.0.4-py3-none-any.whl"
awk '/^# ===BEGIN WHEEL_B64===/{flag=1; next} /^# ===END WHEEL_B64===/{flag=0} flag {sub(/^# ?/, ""); print}' "$0" | base64 -D > "$WHEEL_PATH" 2>/dev/null \
  || awk '/^# ===BEGIN WHEEL_B64===/{flag=1; next} /^# ===END WHEEL_B64===/{flag=0} flag {sub(/^# ?/, ""); print}' "$0" | base64 -d > "$WHEEL_PATH"
"$VENV_DIR/bin/python" -m pip install --quiet --upgrade pip
"$VENV_DIR/bin/python" -m pip install --quiet --force-reinstall "$WHEEL_PATH"
"$VENV_DIR/bin/python" -c "import schedule_forensics" || { echo "The tool failed to import after install." >&2; exit 1; }
ok "Installed schedule_forensics-1.0.4-py3-none-any.whl"
# optional HUD telemetry enhancer (CPU% / temps on macOS) — best-effort, never fatal
"$VENV_DIR/bin/python" -m pip install --quiet psutil >/dev/null 2>&1 || true

# --- 4. Ollama + this tier's local AI model -------------------------------------------
step "Local AI ($OLLAMA_MODEL) — the tool runs fully without it (skippable)"
if [ "$SMOKE" = "1" ]; then
  warn "Smoke mode: skipping AI install"
else
  read -r -p "    Install Ollama + pull '$OLLAMA_MODEL' (~${MODEL_DISK_GB} GB download)? [Y/n] " ans || ans="n"
  if [[ ! "$ans" =~ ^[Nn] ]]; then
    if ! command -v ollama >/dev/null 2>&1; then
      if command -v brew >/dev/null 2>&1; then
        brew install --cask ollama
        ok "Ollama installed (Homebrew)"
      else
        warn "Homebrew not found — download Ollama from https://ollama.com/download, then run: ollama pull $OLLAMA_MODEL"
      fi
    else
      ok "Ollama already present"
    fi
    if command -v ollama >/dev/null 2>&1; then
      echo "    Pulling $OLLAMA_MODEL (this is the big download)..."
      ollama pull "$OLLAMA_MODEL"
      ok "Model ready: $OLLAMA_MODEL"
    fi
  else
    warn "Skipped — the tool works fully offline; AI prose stays off until a model is installed"
  fi
fi

# --- 5. Desktop Start/Stop launchers, uninstaller, README -----------------------------
step "Creating Start/Stop launchers, uninstaller, and first-run README"
START_CMD="$INSTALL_ROOT/Start Schedule Forensics.command"
cat > "$START_CMD" <<EOF
#!/usr/bin/env bash
exec "$VENV_DIR/bin/python" -c "from schedule_forensics.launcher import main; main(port=$APP_PORT)"
EOF
chmod +x "$START_CMD"

STOP_CMD="$INSTALL_ROOT/Stop Schedule Forensics.command"
cat > "$STOP_CMD" <<EOF
#!/usr/bin/env bash
curl -fsS -X POST "http://127.0.0.1:$APP_PORT/api/shutdown" >/dev/null 2>&1 \\
  && echo "Schedule Forensics stopped." || echo "Not running (or already stopped)."
sleep 2
EOF
chmod +x "$STOP_CMD"

UNINST="$INSTALL_ROOT/Uninstall Schedule Forensics.command"
cat > "$UNINST" <<EOF
#!/usr/bin/env bash
# Removes the app folder + Desktop launchers. Leaves Python/Ollama (shared programs);
# remove the AI model with:  ollama rm $OLLAMA_MODEL
"$STOP_CMD" || true
rm -f "\$HOME/Desktop/Start Schedule Forensics.command" "\$HOME/Desktop/Stop Schedule Forensics.command"
rm -rf "$INSTALL_ROOT"
echo "Schedule Forensics removed."
EOF
chmod +x "$UNINST"

cat > "$INSTALL_ROOT/FIRST-RUN-README.txt" <<EOF
Schedule Forensics — first run
==============================
Start:  double-click "Start Schedule Forensics" on the Desktop.
        Your browser opens http://127.0.0.1:$APP_PORT — everything runs ON THIS MACHINE.
Stop:   double-click "Stop Schedule Forensics" (closing the browser also stops it).
Data:   your schedule files NEVER leave this computer (loopback-only by design).
AI:     enable it in AI Settings inside the app (model: $OLLAMA_MODEL).
Remove: "Uninstall Schedule Forensics.command" in $INSTALL_ROOT.
EOF

if [ "$SMOKE" != "1" ]; then
  cp "$START_CMD" "$HOME/Desktop/" 2>/dev/null || true
  cp "$STOP_CMD" "$HOME/Desktop/" 2>/dev/null || true
  ok "Desktop launchers + uninstaller + README in $INSTALL_ROOT"
else
  ok "Smoke mode: launchers written to $INSTALL_ROOT only"
fi

echo ""
printf '\033[32mDONE — double-click "Start Schedule Forensics" on the Desktop to begin.\033[0m\n'
echo "(Everything runs locally at http://127.0.0.1:$APP_PORT — no data leaves this machine.)"
exit 0

